# Sample systemd unit for running the resident daemon.
#
# Prerequisites:
#   sudo useradd --system --home /var/lib/resident --shell /usr/sbin/nologin resident
#   sudo install -m 0700 -o resident -g resident -d /etc/resident
#   sudo install -m 0600 -o resident -g resident /dev/null /etc/resident/env
#   # Add SLACK_BOT_TOKEN / SLACK_APP_TOKEN / ANTHROPIC_API_KEY to /etc/resident/env.
#   # Optionally drop /etc/resident/config.toml (mode 0600) for TOML config overrides.
#   sudo install -m 0755 dist/resident /usr/local/bin/resident
#
# Install:
#   sudo cp examples/resident.service /etc/systemd/system/resident.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now resident
#   sudo journalctl -u resident -f
#
# Notes:
# - Wants/After=network-online.target only delivers ordering if a *-wait-online.service
#   is enabled on the host (systemd-networkd-wait-online or NetworkManager-wait-online).
#   Without it, expect a ~2 min target timeout at boot; remove the wait if Slack's own
#   reconnect is preferred to deferring start.
# - This unit targets the compiled binary `/usr/local/bin/resident` produced by
#   `bun build --compile`. To run from source, set ExecStart to your bun's absolute path
#   plus `src/daemon.ts`, and add Environment=PATH or BindReadOnlyPaths for bun's cache.

[Unit]
Description=resident — Slack-resident Claude bot daemon
Documentation=https://github.com/mickamy/resident
After=network-online.target
Wants=network-online.target

# Cap restart storms: if the unit exits >5 times within 5min, hold off.
StartLimitIntervalSec=300
StartLimitBurst=5

[Service]
Type=simple
User=resident
Group=resident

ExecStart=/usr/local/bin/resident
WorkingDirectory=/var/lib/resident

# Stay up across crashes; do NOT restart on a clean exit-0 (graceful drain).
Restart=on-failure
RestartSec=10s

# Give the daemon enough headroom to drain in-flight handlers.
# Must exceed RESIDENT_SHUTDOWN_DRAIN_TIMEOUT_MS (default 60s) + ~5s abort grace.
TimeoutStopSec=120s

# Logs go to journald; query with `journalctl -u resident`.
StandardOutput=journal
StandardError=journal

# Make config path explicit so the daemon does not fall back to ~/.resident,
# which is unreachable under ProtectHome=true.
Environment=RESIDENT_CONFIG=/etc/resident/config.toml

# Secrets — keep these in /etc/resident/env (chmod 0600, owned by resident:resident).
# Leading '-' makes the file optional so the unit can start before /etc/resident/env
# exists; the daemon will then exit 1 at startup with a clear error.
EnvironmentFile=-/etc/resident/env

# Filesystem isolation.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
# StateDirectory (systemd 235+) creates /var/lib/resident with the right
# ownership/permissions and grants the unit write access to it.
StateDirectory=resident
ConfigurationDirectory=resident
ConfigurationDirectoryMode=0700

# Kernel / IPC isolation — cheap wins surfaced by `systemd-analyze security resident`.
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectKernelLogs=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
RestrictNamespaces=true
RestrictRealtime=true
RestrictSUIDSGID=true
LockPersonality=true
SystemCallArchitectures=native

[Install]
WantedBy=multi-user.target
